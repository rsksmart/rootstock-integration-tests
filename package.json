    "@rsksmart/rootstock-transaction-helper": "github:rsksmart/rootstock-transaction-helper#v6.0.0",
    "@rsksmart/rsk-precompiled-abis": "9.0.0-VETIVER",
    "bitcoinjs-lib": "7.0.1",
    "bn.js": "5.2.5",
    "chai": "4.5.0",
    "chai-as-promised": "7.1.2",
    "colors": "1.4.0",
